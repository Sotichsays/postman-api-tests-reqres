    {
      "name": "Get and save user token",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Проверяем, что статус ответа 200 (успешный вход)",
              "pm.test(\"Login successful - status 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "// Проверяем, что в ответе есть токен",
              "pm.test(\"Response contains token\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('token');",
              "});",
              "",
              "// СОХРАНЯЕМ ТОКЕН В ПЕРЕМЕННУЮ ОКРУЖЕНИЯ",
              "var jsonData = pm.response.json();",
              "if (jsonData.token) {",
              "    pm.environment.set(\"my_token\", jsonData.token);",
              "    console.log(\"✅ Токен сохранён:\", jsonData.token);",
              "} else {",
              "    console.log(\"❌ Токен не найден в ответе\");",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "x-api-key",
            "value": "reqres_63b259783dbd43fc9d6c2ebea2233fe4",
